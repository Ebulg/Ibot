# Servidor
PORT=4310
NODE_ENV=production
PUBLIC_BASE_URL=http://localhost:4310

# MongoDB v2. Recomendado usar una DB nueva para no tocar la vieja.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=Ibotv2

# Seguridad del panel con login/registro y cookie HTTP-only.
PANEL_AUTH_ENABLED=true
PANEL_SECRET=cambia_este_secreto_largo_y_unico
PANEL_SESSION_DAYS=7
# En HTTPS real puedes activar cookie Secure.
COOKIE_SECURE=false
# Por seguridad, el registro público queda cerrado después del primer usuario.
PANEL_ALLOW_PUBLIC_REGISTRATION=false

# Z.AI opcional. También puede configurarse desde el panel.
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-5.1

# Almacenamiento local de sesiones, logs y chats por cuenta.
STORAGE_DIR=storage/accounts
