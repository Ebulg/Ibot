{
  "name": "ibot-v2-whatsapp",
  "version": "2.0.0",
  "description": "Ibot v2 - Bot de WhatsApp multi cuenta con panel, grupos, logs locales, chats y modo IA",
  "type": "module",
  "main": "server.js",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "check": "node --check server.js && find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "audit": "pnpm audit --audit-level moderate",
    "install:secure": "pnpm install --frozen-lockfile",
    "migrate:v1": "node scripts/migrate-v1-to-v2.js"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "bot",
    "nodejs",
    "pnpm"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "mongodb": "7.2.0",
    "qrcode": "1.5.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0"
  }
}
